APP_NAME=NOCTAMBULE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_TIMEZONE=Europe/Paris

# Base de données — PostgreSQL (service "postgres" du docker-compose)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=noctambule
DB_USERNAME=noctambule
DB_PASSWORD=secret

# Redis — client Predis (pur PHP : l'image n'embarque pas l'extension phpredis)
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache / sessions / files d'attente via Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# OpenWeatherMap — météo Nantes (endpoint GET /api/v1/weather)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Nantes,FR
