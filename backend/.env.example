APP_NAME=NOCTAMBULE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_TIMEZONE=Europe/Paris

# Base de données — PostgreSQL (service "postgres" du docker-compose)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=noctambule
DB_USERNAME=noctambule
DB_PASSWORD=secret

# Redis — client Predis (pur PHP : l'image n'embarque pas l'extension phpredis)
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache / sessions / files d'attente via Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Météo — Open-Meteo (gratuit, sans clé). Coordonnées Nantes par défaut.
# WEATHER_LATITUDE=47.2184
# WEATHER_LONGITUDE=-1.5536

# Transports TAN/Naolib — API publique sans clé. L'hôte historique open.tan.fr ne
# sert plus le temps réel (remplacé par du SIRI à clé) ; le miroir v2 preprod si.
# TAN_API_URL=https://openv2-preprod.tan.fr/ewp

# Narration IA — Mistral (provider par défaut du plan, modèle free tier).
# Clé sur https://console.mistral.ai ; laisser vide => repli sur une narration locale.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Partage de soirée par email — Resend (clé dans .env, jamais committée).
# RESEND_FROM doit pointer un domaine vérifié sur Resend pour écrire à n'importe
# quelle adresse ; sinon l'expéditeur de test ne livre qu'au propriétaire du compte.
RESEND_API_KEY=
RESEND_FROM="NOCTAMBULE <onboarding@resend.dev>"

# URL du front (liens cliquables dans les emails)
FRONTEND_URL=http://localhost:5173

# Documentation OpenAPI (Swagger UI sur /api/documentation).
# La spec est générée au boot du conteneur ; passer GENERATE_ALWAYS à true en dev
# pour la régénérer à chaque requête pendant qu'on annote.
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=http://localhost:8000
