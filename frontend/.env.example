# Base URL for the NOCTAMBULE backend API (Laravel /api/v1/*).
# In dev, this is the URL exposed by docker-compose (default: http://localhost:8000).
VITE_API_BASE_URL=http://localhost:8000

# Set to "true" to enable MSW (Mock Service Worker) and intercept API calls in dev.
# Useful while the backend is not yet wired up.
VITE_USE_MOCKS=false
